{
  "name": "marlow-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/marlow-api/src",
  "projectType": "application",
  "tags": ["type:app", "scope:marlow"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "apps/marlow-api/dist",
        "format": ["cjs"],
        "bundle": true,
        "thirdParty": true,
        "excludeFromExternal": [
          "@org/marlow-domain",
          "@org/marlow-application",
          "@org/marlow-api-contracts",
          "@org/marlow-api-errors",
          "@org/marlow-infrastructure-github",
          "@org/marlow-infrastructure-credentials"
        ],
        "main": "apps/marlow-api/src/main.ts",
        "tsConfig": "apps/marlow-api/tsconfig.app.json",
        "assets": ["apps/marlow-api/src/assets"],
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/apps/marlow-api/dist/package.json",
        "{workspaceRoot}/apps/marlow-api/dist/pnpm-lock.yaml"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/apps/marlow-api/dist/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "marlow-api:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "marlow-api:build:development"
        },
        "production": {
          "buildTarget": "marlow-api:build:production"
        }
      }
    }
  }
}
